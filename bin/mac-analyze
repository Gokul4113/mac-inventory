#!/usr/bin/env python3
"""
mac-analyze
-----------
Scans mac-inventory JSON output for potential vulnerabilities using the NVD API.
"""

import json
import csv
import sys
import os
import re
import time
import argparse
import urllib.request
import urllib.error
import urllib.parse
import ssl
from pathlib import Path
from typing import List, Dict, Any, Optional, Tuple

# ── Config ──────────────────────────────────────────────────────────────────

def load_api_key() -> str:
    """Load NVD API key from environment variable or .env file."""
    # 1. Check environment variable first
    key = os.environ.get("NVD_API_KEY", "").strip()
    if key:
        return key

    # 2. Search for .env file (script dir → parent → cwd)
    search_dirs = [
        Path(__file__).resolve().parent.parent,  # project root
        Path(__file__).resolve().parent,          # bin/
        Path.cwd(),                               # current directory
    ]
    for d in search_dirs:
        env_file = d / ".env"
        if env_file.is_file():
            try:
                for line in env_file.read_text().splitlines():
                    line = line.strip()
                    if line.startswith("#") or "=" not in line:
                        continue
                    k, v = line.split("=", 1)
                    if k.strip() == "NVD_API_KEY":
                        return v.strip()
            except OSError:
                continue

    return ""


BASE_CVE_URL = "https://services.nvd.nist.gov/rest/json/cves/2.0"
REQ_TIMEOUT = 15
MAX_RETRIES = 3

# Without API key: 5 req/30s (~6s delay); With key: 50 req/30s (~0.6s delay)
def get_rate_delay(has_key: bool) -> float:
    return 0.6 if has_key else 6.0

# ── Known Vendor Mappings ───────────────────────────────────────────────────
# Maps normalized product names to their correct CPE vendor strings.
# This dramatically reduces false positives from naive first-word guessing.

