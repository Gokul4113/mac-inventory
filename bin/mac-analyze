#!/usr/bin/env python3
"""
mac-analyze
-----------
Vulnerability scanner for macOS inventory data.

Features:
- Resolves CPE names via NVD CPE API (cpes/2.0) with strict validation.
- Fetches all CVEs using pagination.
- Tags CISA KEV (Known Exploited Vulnerabilities).
- Scans both Applications and Package Receipts.
- Implements strict confidence scoring to minimize false positives.

Usage:
    mac-analyze -i <inventory_json> -o <output_csv> [--kev]

Requires:
- python3
- network access to NVD API

Configuration:
- Set NVD_API_KEY env var or add to .env file for higher rate limits.
"""

import argparse
import csv
import json
import os
import re
import ssl
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

# ─────────────────────────────────────────────────────────────────────────────
# Config
# ─────────────────────────────────────────────────────────────────────────────

BASE_CVE_URL = "https://services.nvd.nist.gov/rest/json/cves/2.0"
BASE_CPE_URL = "https://services.nvd.nist.gov/rest/json/cpes/2.0"
KEV_URL_DEFAULT = "https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json"

REQ_TIMEOUT = 20
MAX_RETRIES = 3

# NVD max resultsPerPage is high (commonly 2000). Use 2000 to reduce paging requests.
CVE_RESULTS_PER_PAGE = 2000
CPE_RESULTS_PER_PAGE = 200

# Without API key: 5 req/30s (~6s delay); With key: 50 req/30s (~0.6s delay)
def get_rate_delay(has_key: bool) -> float:
    return 0.6 if has_key else 6.0

# System paths to skip — OS-managed; creates lots of false positives.
SYSTEM_PATH_PREFIXES = (
    "/System/",
    "/Library/Apple/",
    "/usr/libexec/",
    "/usr/sbin/",
    "/usr/bin/",
    "/bin/",
    "/sbin/",
)

# Known Apple system apps by normalized name (OS-managed)
APPLE_SYSTEM_APPS = {
