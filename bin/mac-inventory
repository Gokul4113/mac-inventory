#!/usr/bin/env bash
set -euo pipefail

VERSION="1.2.0"
PROGRAM_NAME="mac-inventory"

# ── Output Helpers ──

green()  { printf '\033[1;32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[1;33m%s\033[0m\n' "$*"; }
red()    { printf '\033[1;31m%s\033[0m\n' "$*"; }
info()   { printf '  → %s\n' "$*"; }

usage() {
  cat <<EOF
${PROGRAM_NAME} v${VERSION}
Collect a full macOS software inventory and export it as JSON or CSV.

USAGE
  ${PROGRAM_NAME} [OPTIONS]

OPTIONS
  -o, --output DIR       Output directory (default: ./osq_out)
  -f, --format FORMAT    Output format: json, csv, or all (default: json)
  -s, --scan             Run vulnerability scan (checks NVD for CVEs)
  -v, --version          Print version and exit
  -h, --help             Show this help message

EXAMPLES
  ${PROGRAM_NAME}
  ${PROGRAM_NAME} --scan
  ${PROGRAM_NAME} -f all -o ~/Desktop/audit --scan

REQUIREMENTS
  osquery, jq (installed automatically via Homebrew tap)
  python3 (required only for --scan)
EOF
}

# ── Argument Parser ──

parse_args() {
  OUT_DIR="./osq_out"
  OUTPUT_FORMAT="json"
  RUN_SCAN=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -o|--output)
        [[ -z "${2:-}" ]] && { red "ERROR: --output requires a directory path"; exit 1; }
        OUT_DIR="$2"; shift 2 ;;
      -f|--format)
        [[ -z "${2:-}" ]] && { red "ERROR: --format requires a value (json, csv, or all)"; exit 1; }
        OUTPUT_FORMAT="$2"; shift 2 ;;
      -s|--scan)   RUN_SCAN=true; shift ;;
      -v|--version) echo "${PROGRAM_NAME} ${VERSION}"; exit 0 ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  if [[ "$OUTPUT_FORMAT" != "json" && "$OUTPUT_FORMAT" != "csv" && "$OUTPUT_FORMAT" != "all" ]]; then
    red "ERROR: Invalid format '${OUTPUT_FORMAT}'. Use: json, csv, or all"
    exit 1
  fi
}

# ── Dependency Check ──

check_dependencies() {
  OSQUERYI="$(command -v osqueryi || true)"
  if [[ -z "${OSQUERYI}" ]]; then
    red "ERROR: osqueryi not found. Install with: brew install osquery"
    exit 1
  fi

  if ! command -v jq >/dev/null 2>&1; then
    red "ERROR: jq not found. Install with: brew install jq"
    exit 1
  fi

  if [[ "$RUN_SCAN" == "true" ]]; then
    if ! command -v python3 >/dev/null 2>&1; then
      red "ERROR: python3 not found (required for --scan)."
      exit 1
    fi
  fi
}

# ── Query Definitions (Bash 3.2 Compatible) ──

QUERY_NAMES=()
QUERY_SQL=()

register_queries() {
  # Apps
  QUERY_NAMES[0]="apps"
  QUERY_SQL[0]="SELECT name, bundle_identifier, bundle_short_version AS version, bundle_version AS build, path FROM apps ORDER BY name"

  # Package Receipts
  QUERY_NAMES[1]="package_receipts"
  QUERY_SQL[1]="SELECT package_id, version, install_time, installer_name, location, path FROM package_receipts ORDER BY install_time DESC"

  # Homebrew
  QUERY_NAMES[2]="homebrew_packages"
  QUERY_SQL[2]="SELECT name, version, path FROM homebrew_packages ORDER BY name"

  # Startup Items
  QUERY_NAMES[3]="startup_items"
  QUERY_SQL[3]="SELECT name, type, status, username, path FROM startup_items ORDER BY name"

  # Kernel Extensions
  QUERY_NAMES[4]="kernel_extensions"
  QUERY_SQL[4]="SELECT name, version, path, idx, linked_against FROM kernel_extensions ORDER BY name"

  # Safari Extensions
  QUERY_NAMES[5]="safari_extensions"
  QUERY_SQL[5]="SELECT u.username, e.name, e.identifier, e.version, e.bundle_version, e.path FROM users u JOIN safari_extensions e ON u.uid = e.uid ORDER BY u.username, e.name"

  # OS Version
  QUERY_NAMES[6]="os_version"
  QUERY_SQL[6]="SELECT name, version, major, minor, patch, build, arch FROM os_version"

  # Processes
  QUERY_NAMES[7]="processes"
  QUERY_SQL[7]="SELECT name, pid, path, cmdline FROM processes ORDER BY name"

  # Launchd
  QUERY_NAMES[8]="launchd"
  QUERY_SQL[8]="SELECT name, path, program, run_at_load, keep_alive FROM launchd ORDER BY name"
}

# ── Query Runner ──

run_query() {
  local name="$1"
  local sql="$2"
  local index="$3"
  local total="$4"

  printf '  [%d/%d] Collecting %-25s' "$index" "$total" "${name}..."

  if "$OSQUERYI" --json "$sql" > "${OUT_DIR}/${name}.json" 2> "${OUT_DIR}/${name}.err"; then
    rm -f "${OUT_DIR}/${name}.err"
    green " ✓"
  else
    local err
    err="$(tail -n 200 "${OUT_DIR}/${name}.err" 2>/dev/null | jq -Rs . 2>/dev/null || echo '""')"
    echo "{\"error\": ${err}}" > "${OUT_DIR}/${name}.json"
    yellow " ⚠ (see ${name}.err)"
  fi
}

collect_all() {
  local total=${#QUERY_NAMES[@]}
  
  # Bash 3.2 loop over array indices
  for (( i=0; i<total; i++ )); do
    local idx=$((i + 1))
    run_query "${QUERY_NAMES[$i]}" "${QUERY_SQL[$i]}" "$idx" "$total"
  done
}

# ── Metadata Collector ──

collect_metadata() {
  info "Collecting system metadata..."

  NOW_UTC="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  HOST="$(scutil --get LocalHostName 2>/dev/null || hostname)"
  OS_VER="$(sw_vers -productVersion 2>/dev/null || echo "")"
  OS_BUILD="$(sw_vers -buildVersion 2>/dev/null || echo "")"
  SERIAL="$(system_profiler SPHardwareDataType 2>/dev/null \
    | awk -F': ' '/Serial Number/{print $2; exit}' || true)"
  ARCH="$(uname -m 2>/dev/null || true)"
}

# ── JSON Aggregator ──

merge_to_json() {
  info "Merging into final JSON..."

  local slurp_args=()
  for name in "${QUERY_NAMES[@]}"; do
    slurp_args+=(--slurpfile "$name" "${OUT_DIR}/${name}.json")
  done

  jq -n \
    --arg collected_at "$NOW_UTC" \
    --arg hostname "$HOST" \
    --arg os_version_sw "$OS_VER" \
    --arg os_build_sw "$OS_BUILD" \
    --arg serial "$SERIAL" \
    --arg arch_uname "$ARCH" \
    --arg tool_version "$VERSION" \
    "${slurp_args[@]}" \
    '{
      metadata: {
        collected_at: $collected_at,
        device: {
          hostname: $hostname,
          serial_number: ($serial | select(. != "")),
          os: "macOS",
          os_version: $os_version_sw,
          os_build: $os_build_sw,
          arch: $arch_uname
        },
        generator: {
          tool: "mac-inventory",
          tool_version: $tool_version,
          engine: "osqueryi",
          format: "mac-inventory-pack-v1"
        }
      },
      data: {
        os_version: ($os_version[0] // []),
        apps: ($apps[0] // []),
        package_receipts: ($package_receipts[0] // []),
        homebrew_packages: ($homebrew_packages[0] // []),
        startup_items: ($startup_items[0] // []),
        kernel_extensions: ($kernel_extensions[0] // []),
        safari_extensions: ($safari_extensions[0] // []),
        processes: ($processes[0] // []),
        launchd: ($launchd[0] // [])
      }
    }' > "${OUT_DIR}/final_inventory.json"
}

# ── CSV Exporter ──

json_to_csv() {
  local json_file="$1"
  local csv_file="$2"

  local has_data
  has_data="$(jq 'if type == "array" and length > 0 then "yes" else "no" end' "$json_file" 2>/dev/null || echo "no")"

  if [[ "$has_data" == '"yes"' ]]; then
    local headers
    headers="$(jq -r '.[0] | keys_unsorted | @csv' "$json_file")"
    echo "$headers" > "$csv_file"
    jq -r '.[] | [.[]] | @csv' "$json_file" >> "$csv_file"
  else
    echo "" > "$csv_file"
  fi
}

export_csv() {
  info "Exporting to CSV..."
  local csv_dir="${OUT_DIR}/csv"
  mkdir -p "$csv_dir"

  for name in "${QUERY_NAMES[@]}"; do
    local json_file="${OUT_DIR}/${name}.json"
    local csv_file="${csv_dir}/${name}.csv"

    if [[ -f "$json_file" ]]; then
      json_to_csv "$json_file" "$csv_file"
    fi
  done

  info "CSV files saved to: ${csv_dir}/"
}

# ── Vulnerability Scanner ──

run_scan() {
  if [[ "$RUN_SCAN" != "true" ]]; then
    return
  fi

  echo ""
  green "════════════════════════════════════════════════"
  green " 🛡️  Starting Vulnerability Scan (NVD)"
  green "════════════════════════════════════════════════"
  
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local analyzer="${script_dir}/mac-analyze"
  local output_csv="${OUT_DIR}/security_audit.csv"

  if [[ ! -f "$analyzer" ]]; then
    red "ERROR: Vulnerability analyzer not found at: ${analyzer}"
    return
  fi

  python3 "$analyzer" \
    --input "${OUT_DIR}/final_inventory.json" \
    --output "$output_csv"
}

# ── Summary Reporter ──

print_summary() {
  local apps_count pkgs_count brew_count
  apps_count="$(jq '.data.apps | length' "${OUT_DIR}/final_inventory.json" 2>/dev/null || echo '?')"
  pkgs_count="$(jq '.data.package_receipts | length' "${OUT_DIR}/final_inventory.json" 2>/dev/null || echo '?')"
  brew_count="$(jq '.data.homebrew_packages | length' "${OUT_DIR}/final_inventory.json" 2>/dev/null || echo '?')"

  echo ""
  green "════════════════════════════════════════════════"
  green "  Inventory complete!"
  green "════════════════════════════════════════════════"
  echo ""
  info "Format:           ${OUTPUT_FORMAT}"

  if [[ "$OUTPUT_FORMAT" == "json" || "$OUTPUT_FORMAT" == "all" ]]; then
    info "JSON:  ${OUT_DIR}/final_inventory.json"
  fi
  if [[ "$OUTPUT_FORMAT" == "csv" || "$OUTPUT_FORMAT" == "all" ]]; then
    info "CSV:   ${OUT_DIR}/csv/"
  fi

  info "Apps found:       ${apps_count}"
  info "PKG receipts:     ${pkgs_count}"
  info "Brew packages:    ${brew_count}"
  
  if [[ "$RUN_SCAN" == "true" ]]; then
    echo ""
    info "Security Audit:   ${OUT_DIR}/security_audit.csv"
  fi
  
  info "Host:             ${HOST}"
  info "macOS:            ${OS_VER} (${OS_BUILD})"
  echo ""
}

# ── Banner ──

print_banner() {
  echo ""
  green "╔════════════════════════════════════════════╗"
  green "║       mac-inventory  v${VERSION}             ║"
  green "╚════════════════════════════════════════════╝"
  echo ""
  info "Output directory: ${OUT_DIR}"
  info "Format:           ${OUTPUT_FORMAT}"
  if [[ "$RUN_SCAN" == "true" ]]; then
    info "Scan Mode:        ENABLED (checking NVD)"
  fi
  echo ""
}

# ── Main ──

main() {
  parse_args "$@"
  check_dependencies
  register_queries
  mkdir -p "$OUT_DIR"
  print_banner
  collect_all
  echo ""
  collect_metadata
  merge_to_json

  if [[ "$OUTPUT_FORMAT" == "csv" || "$OUTPUT_FORMAT" == "all" ]]; then
    export_csv
  fi

  run_scan
  print_summary
}

main "$@"
